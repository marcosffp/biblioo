package "recommendation" #FBFBF2 {

  class UserPreference {
    -id : Long
    -userId : Long
    -genres : List<String>
    -bookIds : List<Long>
    -createdAt : LocalDateTime
    -updatedAt : LocalDateTime
    +savePreferences(userId, genres, bookIds) : UserPreference
    +getAllGenres() : List<GenreTranslation>
  }

  class RecommendationResult {
    -id : Long
    -userId : Long
    -trailType : String
    -books : String (JSON)
    -computedAt : LocalDateTime
    -metadata : String (JSON)
    +getBecauseYouRead(userId) : BecauseYouReadResult
    +getFavoriteGenreNow(userId) : FavoriteGenreNowResult
    +getTrendingInCommunities(userId) : TrendingInCommunitiesResult
    +getCatalogSurprise(userId) : CatalogSurpriseResult
    +getRereadWorthIt(userId) : RereadWorthItResult
    +getSimilarAuthors(userId) : SimilarAuthorsResult
    +rollDice(userId) : DiceRollResult
  }

  class CommunityTrendingScore {
    -bookId : Long
    -currentScore : Double
    -lastUpdated : LocalDateTime
  }
}

' ###################################################################
package "notification" #FBF2F7 {

  class Notification {
    -id : String
    -recipientId : Long
    -type : NotificationType
    -actorId : Long
    -actorUsername : String
    -actorAvatarUrl : String
    -entityId : Long
    -communityId : Long
    -readAt : LocalDateTime
    -createdAt : LocalDateTime
    +getNotifications(userId, page, size) : List<Notification>
    +countUnread(userId) : long
    +markAsRead(notificationId) : void
    +markAllAsRead(userId) : void
    +isRead() : boolean
  }

  class DeviceToken {
    -id : Long
    -userId : Long
    -token : String
    -createdAt : LocalDateTime
  }

  enum NotificationType {
    USER_FOLLOW_REQUESTED
    USER_FOLLOWED
    COMMENT_REPLIED
    REVIEW_LIKED
    COMMUNITY_INVITE
    COMMUNITY_JOIN_REQUEST
    COMMUNITY_JOIN_APPROVED
  }

  Notification --> NotificationType
}

' ===================================================================
' Referencias inter-modulo (por ID, modulo isolado) ----------------
' ===================================================================
Shelf ..> User
Collection ..> User
ShelfItem ..> Book
ReadingActiveDay ..> User
ReadingActiveDay ..> Book
RefreshToken ..> User
PasswordResetToken ..> User
UserFollow ..> User

Community ..> Book
Community ..> User
CommunityMember ..> User
BookVotingOption ..> Book

FeedPost ..> User
FeedPost ..> Book
Review ..> Book
FeedItem ..> User

LiteraryDna ..> User
UserPreference ..> User
CommunityTrendingScore ..> Book
Notification ..> User
DeviceToken ..> User
@enduml
